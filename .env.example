# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Set to "false" to use real Claude API, "true" for mock responses
USE_DUMMY=false

# Server
PORT=3001
NODE_ENV=production

# SQLite — set to Railway volume path in production
DB_PATH=/data/mymind.db

# Skip Chromium download (Railway / CI)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
